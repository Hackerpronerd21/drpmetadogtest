@inherits PanelComponent
@namespace DarkRp
@using System.Linq

@*
    F4 Job Menu.

    Attach this as a component on any scene GameObject (e.g. "JobMenu").
    Opens/closes on the "JobMenu" input action (F4).
    Calls PlayerState.RequestJobChange — the RPC fires to the host for
    validation. UI never decides; it only requests.
*@

@{
    var state = Game.ActiveScene?
        .GetAllComponents<PlayerState>()
        .FirstOrDefault( s => s.Network.OwnerConnection == Connection.Local );
}

<root>
    @if ( IsOpen )
    {
        <div class="jm-overlay">
            <div class="jm-panel">

                <div class="jm-header">
                    <span class="jm-title">Choose Your Job</span>
                    <button class="jm-close-btn" @onclick="Close">✕</button>
                </div>

                <div class="jm-grid">
                    @foreach ( var job in JobRegistry.All.OrderBy( j => j.SalaryAmount ) )
                    {
                        var isCurrent  = state?.JobId == job.Id;
                        var slotCount  = JobRegistry.CountPlayersInJob( job.Id );
                        var isFull     = job.MaxSlots >= 0
                                         && slotCount >= job.MaxSlots
                                         && !isCurrent;

                        <div class="jm-card @(isCurrent ? "is-current" : "") @(isFull ? "is-full" : "")"
                             @onclick="() => SelectJob( job.Id )">

                            <div class="jm-stripe" style="background-color: @Hex( job.Color )"></div>

                            <div class="jm-body">
                                <div class="jm-name" style="color: @Hex( job.Color )">@job.DisplayName</div>
                                <div class="jm-desc">@job.Description</div>
                                <div class="jm-meta">
                                    <span class="jm-salary">$@job.SalaryAmount / salary</span>
                                    <span class="jm-slots @(isFull ? "slots-full" : "")">
                                        @if ( job.MaxSlots < 0 )
                                        {
                                            <text>∞ slots</text>
                                        }
                                        else
                                        {
                                            <text>@slotCount/@job.MaxSlots slots</text>
                                        }
                                    </span>
                                </div>
                            </div>

                            @if ( isCurrent )
                            {
                                <div class="jm-badge badge-current">CURRENT</div>
                            }
                            else if ( isFull )
                            {
                                <div class="jm-badge badge-full">FULL</div>
                            }

                        </div>
                    }
                </div>

                <div class="jm-footer">F4 to close  ·  click a job to switch</div>
            </div>
        </div>
    }
</root>

@code {

    bool IsOpen { get; set; }

    protected override void OnUpdate()
    {
        if ( Input.Pressed( "JobMenu" ) )
            Toggle();
    }

    void Toggle()
    {
        SetOpen( !IsOpen );
    }

    void Close()
    {
        SetOpen( false );
    }

    void SetOpen( bool open )
    {
        IsOpen = open;
        // Unlock the cursor so the player can click job cards.
        // s&box PlayerController suppresses look input while the cursor is visible.
        Mouse.Visible = open;
        StateHasChanged();
    }

    void SelectJob( string jobId )
    {
        // Re-resolve here; the top-of-render var doesn't carry into event handlers.
        var state = Game.ActiveScene?
            .GetAllComponents<PlayerState>()
            .FirstOrDefault( s => s.Network.OwnerConnection == Connection.Local );

        if ( state is null ) return;

        // This is an [Rpc.Host] call — validation happens on the server.
        // The UI is only a trigger, not the decision-maker.
        state.RequestJobChange( jobId );
        SetOpen( false );
    }

    static string Hex( Color c )
        => $"#{(int)(c.r * 255):X2}{(int)(c.g * 255):X2}{(int)(c.b * 255):X2}";

}

<style>
    /* ── Overlay ─────────────────────────────────────────────── */
    .jm-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(0, 0, 0, 0.55);
    }

    /* ── Panel ───────────────────────────────────────────────── */
    .jm-panel {
        width: 780px;
        max-height: 85%;
        background-color: #1a1c20;
        border: 1px solid #333;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        font-family: Poppins, sans-serif;
    }

    /* ── Header ──────────────────────────────────────────────── */
    .jm-header {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        background-color: #111315;
        border-bottom: 1px solid #2a2d33;
    }

    .jm-title {
        font-size: 18px;
        font-weight: bold;
        color: white;
        letter-spacing: 0.5px;
    }

    .jm-close-btn {
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.5);
        font-size: 18px;
        cursor: pointer;
        padding: 2px 8px;
        border-radius: 4px;
    }

    .jm-close-btn:hover {
        background-color: rgba(255,255,255,0.1);
        color: white;
    }

    /* ── Grid ────────────────────────────────────────────────── */
    .jm-grid {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        gap: 10px;
        padding: 16px;
        overflow-y: auto;
    }

    /* ── Job Card ────────────────────────────────────────────── */
    .jm-card {
        width: 220px;
        background-color: #22252b;
        border: 1px solid #2e3138;
        border-radius: 8px;
        display: flex;
        flex-direction: row;
        overflow: hidden;
        cursor: pointer;
        position: relative;
        transition: background-color 0.1s;
    }

    .jm-card:hover {
        background-color: #2a2e36;
        border-color: #4a5060;
    }

    .jm-card.is-current {
        border-color: #4cff7a;
        background-color: #1e2b21;
    }

    .jm-card.is-full {
        opacity: 0.45;
        cursor: default;
    }

    .jm-card.is-full:hover {
        background-color: #22252b;
        border-color: #2e3138;
    }

    /* ── Color stripe ────────────────────────────────────────── */
    .jm-stripe {
        width: 5px;
        flex-shrink: 0;
    }

    /* ── Card body ───────────────────────────────────────────── */
    .jm-body {
        padding: 10px 10px 10px 8px;
        display: flex;
        flex-direction: column;
        gap: 3px;
        flex: 1;
    }

    .jm-name {
        font-size: 13px;
        font-weight: bold;
    }

    .jm-desc {
        font-size: 10px;
        color: rgba(255,255,255,0.5);
        line-height: 1.3;
    }

    .jm-meta {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        margin-top: 5px;
    }

    .jm-salary {
        font-size: 10px;
        color: #4cff7a;
    }

    .jm-slots {
        font-size: 10px;
        color: rgba(255,255,255,0.4);
    }

    .slots-full {
        color: #ff5050;
    }

    /* ── Badges ──────────────────────────────────────────────── */
    .jm-badge {
        position: absolute;
        top: 6px;
        right: 6px;
        font-size: 8px;
        font-weight: bold;
        letter-spacing: 0.5px;
        padding: 2px 5px;
        border-radius: 3px;
    }

    .badge-current {
        background-color: #4cff7a;
        color: #0a1a0e;
    }

    .badge-full {
        background-color: #ff5050;
        color: white;
    }

    /* ── Footer ──────────────────────────────────────────────── */
    .jm-footer {
        padding: 10px 20px;
        font-size: 10px;
        color: rgba(255,255,255,0.3);
        background-color: #111315;
        border-top: 1px solid #2a2d33;
        text-align: center;
        letter-spacing: 0.3px;
    }
</style>
