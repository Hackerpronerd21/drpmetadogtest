@inherits PanelComponent
@namespace DarkRp
@using System.Linq

@*
    Laws HUD — top-right corner.
    Visible to all players whenever there are active laws or a non-zero tax rate.
    Read-only. The Mayor uses MayorMenu.razor to change these.
*@

@{
    var sys    = Game.ActiveScene?.GetAllComponents<MayorSystem>().FirstOrDefault();
    var laws   = sys?.Laws   ?? System.Array.Empty<string>();
    int taxPct = (int)( ( sys?.TaxRate ?? 0f ) * 100 );
    bool show  = laws.Count > 0 || taxPct > 0;
}

<root>
    @if ( show )
    {
        <div class="lh-panel">

            <div class="lh-header">
                <span class="lh-title">City Laws</span>
                @if ( taxPct > 0 )
                {
                    <span class="lh-tax">Tax: @taxPct%</span>
                }
            </div>

            @if ( laws.Count == 0 )
            {
                <div class="lh-empty">No laws proclaimed.</div>
            }
            else
            {
                @foreach ( var law in laws )
                {
                    <div class="lh-law">• @law</div>
                }
            }

        </div>
    }
</root>

@code { /* read-only panel — no logic needed */ }

<style>
    /* ── Panel ───────────────────────────────────────────────── */
    .lh-panel {
        position: absolute;
        top: 24px;
        right: 24px;
        width: 240px;
        background-color: rgba(0, 0, 0, 0.65);
        border-left: 3px solid #ffd966;
        border-radius: 0 6px 6px 0;
        padding: 8px 12px;
        font-family: Poppins, sans-serif;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    /* ── Header row ──────────────────────────────────────────── */
    .lh-header {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2px;
    }

    .lh-title {
        font-size: 9px;
        font-weight: bold;
        color: #ffd966;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .lh-tax {
        font-size: 9px;
        color: rgba(255, 217, 102, 0.7);
        font-weight: bold;
    }

    /* ── Law rows ────────────────────────────────────────────── */
    .lh-law {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.4;
        word-break: break-word;
    }

    .lh-empty {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.3);
        font-style: italic;
    }
</style>
