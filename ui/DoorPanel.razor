@inherits PanelComponent
@namespace DarkRp
@using System.Linq

@*
    Door panel — two visual modes:

    HINT MODE  (looking at a door, menu closed):
      A small banner at the top-center of the screen.
      Shows door name, owner, lock status, and "Press E to interact".

    MENU MODE  (E pressed on a door):
      A compact action panel. Buttons depend on ownership:
        • Unowned      → [Buy for $X]
        • Own it       → [Lock / Unlock]  [Sell for $X]
        • Others' door → info only

    E closes the menu (DoorInteraction.IsMenuOpen prevents re-open
    on the same frame).
*@

@{
    // Hint mode reads the static CurrentDoor directly (updated every frame).
    var hintDoor = !IsMenuOpen ? DoorInteraction.CurrentDoor : null;

    var localConn = Connection.Local;
    var isOwner   = IsMenuOpen && MenuDoor is not null
                    && MenuDoor.IsOwnedBy( localConn );
    var isOther   = IsMenuOpen && MenuDoor is not null
                    && MenuDoor.IsOwned && !isOwner;
}

<root>

    @* ── Hint banner ──────────────────────────────────────────────────── *@
    @if ( hintDoor is not null )
    {
        <div class="dp-hint">
            <span class="dp-hint-name">@hintDoor.DoorLabel</span>
            @if ( hintDoor.IsOwned )
            {
                <span class="dp-hint-owner">Owned by @hintDoor.OwnerName</span>
            }
            else
            {
                <span class="dp-hint-forsale">For sale — $@hintDoor.BuyPrice</span>
            }
            @if ( hintDoor.IsLocked )
            {
                <span class="dp-hint-locked">🔒 Locked</span>
            }
            <span class="dp-hint-key">[E] Interact</span>
        </div>
    }

    @* ── Action menu ──────────────────────────────────────────────────── *@
    @if ( IsMenuOpen && MenuDoor is not null )
    {
        <div class="dp-overlay">
            <div class="dp-menu">

                <div class="dp-menu-header">
                    <span class="dp-menu-title">@MenuDoor.DoorLabel</span>
                    @if ( MenuDoor.IsLocked )
                    { <span class="dp-locked-badge">LOCKED</span> }
                    <button class="dp-close-btn" @onclick="CloseMenu">✕</button>
                </div>

                <div class="dp-menu-body">
                    @if ( !MenuDoor.IsOwned )
                    {
                        @* ── Unowned: buy ─────────────────────────────────────── *@
                        <p class="dp-info">This property is available.</p>
                        <button class="dp-action dp-buy"
                                @onclick="BuyDoor">
                            Buy for $@MenuDoor.BuyPrice
                        </button>
                    }
                    else if ( isOwner )
                    {
                        @* ── Owner: lock + sell ───────────────────────────────── *@
                        <p class="dp-info dp-owned">You own this property.</p>

                        <button class="dp-action dp-lock"
                                @onclick="ToggleLock">
                            @( MenuDoor.IsLocked ? "Unlock Door" : "Lock Door" )
                        </button>

                        <button class="dp-action dp-sell"
                                @onclick="SellDoor">
                            Sell for $@MenuDoor.SellValue
                        </button>
                    }
                    else
                    {
                        @* ── Owned by someone else ────────────────────────────── *@
                        <p class="dp-info">Owned by <strong>@MenuDoor.OwnerName</strong>.</p>
                        @if ( MenuDoor.IsLocked )
                        { <p class="dp-info dp-warn">This door is locked — you cannot enter.</p> }
                    }
                </div>

                <div class="dp-menu-footer">E to close</div>
            </div>
        </div>
    }

</root>

@code {

    bool       IsMenuOpen { get; set; }
    DoorState? MenuDoor   { get; set; }
    bool       _justOpened;

    protected override void OnStart()
    {
        DoorInteraction.InteractRequested += OpenMenuFor;
    }

    protected override void OnDestroy()
    {
        DoorInteraction.InteractRequested -= OpenMenuFor;
    }

    protected override void OnUpdate()
    {
        // Skip the frame on which the menu was opened — prevents
        // the same E press from immediately closing it.
        if ( _justOpened ) { _justOpened = false; return; }

        if ( IsMenuOpen && Input.Pressed( "Use" ) )
            CloseMenu();
    }

    // ── Open / close ──────────────────────────────────────────────────────

    void OpenMenuFor( DoorState door )
    {
        MenuDoor                   = door;
        IsMenuOpen                 = true;
        DoorInteraction.IsMenuOpen = true;
        Mouse.Visible              = true;
        _justOpened                = true;
        StateHasChanged();
    }

    void CloseMenu()
    {
        IsMenuOpen                 = false;
        MenuDoor                   = null;
        DoorInteraction.IsMenuOpen = false;
        Mouse.Visible              = false;
        StateHasChanged();
    }

    // ── Actions ───────────────────────────────────────────────────────────

    void BuyDoor()
    {
        if ( MenuDoor is null ) return;
        var di = LocalDoorInteraction();
        di?.RequestBuyDoor( MenuDoor.GameObject );
        CloseMenu();
    }

    void SellDoor()
    {
        if ( MenuDoor is null ) return;
        var di = LocalDoorInteraction();
        di?.RequestSellDoor( MenuDoor.GameObject );
        CloseMenu();
    }

    void ToggleLock()
    {
        if ( MenuDoor is null ) return;
        var di = LocalDoorInteraction();
        di?.RequestToggleLock( MenuDoor.GameObject );
        // Stay open so player can see updated lock state immediately.
        StateHasChanged();
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    static DoorInteraction? LocalDoorInteraction()
        => Game.ActiveScene?
            .GetAllComponents<DoorInteraction>()
            .FirstOrDefault( d => d.Network.OwnerConnection == Connection.Local );

}

<style>
    /* ── Hint banner ─────────────────────────────────────────── */
    .dp-hint {
        position: absolute;
        top: 80px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 12px;
        background-color: rgba(0, 0, 0, 0.65);
        border-radius: 6px;
        padding: 6px 16px;
        font-family: Poppins, sans-serif;
        white-space: nowrap;
    }

    .dp-hint-name {
        font-size: 13px;
        font-weight: bold;
        color: white;
    }

    .dp-hint-owner    { font-size: 11px; color: rgba(255,255,255,0.55); }
    .dp-hint-forsale  { font-size: 11px; color: #4cff7a; }
    .dp-hint-locked   { font-size: 11px; color: #ff8c42; }

    .dp-hint-key {
        font-size: 10px;
        color: rgba(255,255,255,0.35);
        letter-spacing: 0.3px;
    }

    /* ── Overlay ─────────────────────────────────────────────── */
    .dp-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(0, 0, 0, 0.5);
    }

    /* ── Menu panel ──────────────────────────────────────────── */
    .dp-menu {
        width: 320px;
        background-color: #1a1c20;
        border: 1px solid #333;
        border-radius: 10px;
        overflow: hidden;
        font-family: Poppins, sans-serif;
    }

    /* ── Header ──────────────────────────────────────────────── */
    .dp-menu-header {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        background-color: #111315;
        border-bottom: 1px solid #2a2d33;
    }

    .dp-menu-title {
        font-size: 15px;
        font-weight: bold;
        color: white;
        flex: 1;
    }

    .dp-locked-badge {
        font-size: 9px;
        font-weight: bold;
        background-color: #ff8c42;
        color: #1a0d00;
        padding: 2px 6px;
        border-radius: 3px;
        letter-spacing: 0.5px;
    }

    .dp-close-btn {
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.4);
        font-size: 16px;
        cursor: pointer;
        padding: 2px 6px;
        border-radius: 4px;
    }

    .dp-close-btn:hover { background-color: rgba(255,255,255,0.1); color: white; }

    /* ── Body ────────────────────────────────────────────────── */
    .dp-menu-body {
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .dp-info {
        font-size: 12px;
        color: rgba(255,255,255,0.55);
        margin: 0 0 4px 0;
    }

    .dp-owned { color: #4cff7a; }
    .dp-warn  { color: #ff8c42; }

    /* ── Action buttons ──────────────────────────────────────── */
    .dp-action {
        width: 100%;
        padding: 9px 0;
        border: none;
        border-radius: 6px;
        font-size: 13px;
        font-weight: bold;
        cursor: pointer;
        font-family: Poppins, sans-serif;
        color: white;
    }

    .dp-buy  { background-color: #2a6e3a; }
    .dp-buy:hover  { background-color: #3a8e4e; }

    .dp-lock { background-color: #3a4a6e; }
    .dp-lock:hover { background-color: #4a5a8e; }

    .dp-sell { background-color: #5a2a2a; }
    .dp-sell:hover { background-color: #7a3a3a; }

    /* ── Footer ──────────────────────────────────────────────── */
    .dp-menu-footer {
        padding: 8px 16px;
        font-size: 10px;
        color: rgba(255,255,255,0.25);
        background-color: #111315;
        border-top: 1px solid #2a2d33;
        text-align: center;
    }
</style>
