@inherits PanelComponent
@namespace DarkRp
@using System.Linq

@*
    Mayor control panel — F6.
    Only renders and responds to input while the local player is Mayor.
    If the player switches jobs while the menu is open it closes automatically.

    Controls:
      Tax rate — [−5%] display [+5%], clamped 0–50%
      Laws     — list with [×] per item + text field to add
      Clear all laws button
*@

@{
    var localState = Game.ActiveScene?
        .GetAllComponents<PlayerState>()
        .FirstOrDefault( s => s.Network.OwnerConnection == Connection.Local );

    bool isMayor   = localState?.JobId == "mayor";
    var  mayorSys  = Game.ActiveScene?.GetAllComponents<MayorSystem>().FirstOrDefault();
    var  laws      = mayorSys?.Laws ?? System.Array.Empty<string>();
    int  taxPct    = (int)( ( mayorSys?.TaxRate ?? 0f ) * 100 );
}

<root>
    @if ( IsOpen && isMayor && mayorSys is not null )
    {
        <div class="mm-overlay">
            <div class="mm-panel">

                <div class="mm-header">
                    <span class="mm-title">Mayor Controls</span>
                    <button class="mm-close-btn" @onclick="Close">✕</button>
                </div>

                <div class="mm-body">

                    @* ── Tax rate ────────────────────────────────────────── *@
                    <div class="mm-section">
                        <div class="mm-section-label">Income Tax Rate</div>
                        <div class="mm-tax-row">
                            <button class="mm-btn mm-btn-minus"
                                    @onclick="() => SetTax( taxPct - 5 )"
                                    disabled="@(taxPct <= 0)">
                                −5%
                            </button>
                            <span class="mm-tax-value">@taxPct%</span>
                            <button class="mm-btn mm-btn-plus"
                                    @onclick="() => SetTax( taxPct + 5 )"
                                    disabled="@(taxPct >= 50)">
                                +5%
                            </button>
                        </div>
                        <div class="mm-tax-hint">
                            @if ( taxPct == 0 )
                            { <text>No tax — citizens keep full salary.</text> }
                            else
                            { <text>Citizens keep @(100 - taxPct)% of their salary.</text> }
                        </div>
                    </div>

                    @* ── Current laws ─────────────────────────────────────── *@
                    <div class="mm-section">
                        <div class="mm-section-label">
                            Active Laws
                            <span class="mm-law-count">@laws.Count / 10</span>
                        </div>

                        @if ( laws.Count == 0 )
                        {
                            <div class="mm-empty">No laws active.</div>
                        }
                        else
                        {
                            <div class="mm-laws-list">
                                @for ( int i = 0; i < laws.Count; i++ )
                                {
                                    int idx = i; // capture for closure
                                    <div class="mm-law-row">
                                        <span class="mm-law-text">@laws[i]</span>
                                        <button class="mm-law-remove"
                                                @onclick="() => RemoveLaw( idx )">
                                            ×
                                        </button>
                                    </div>
                                }
                            </div>
                        }

                        @if ( laws.Count > 0 )
                        {
                            <button class="mm-btn mm-btn-clear"
                                    @onclick="ClearLaws">
                                Repeal all laws
                            </button>
                        }
                    </div>

                    @* ── Add law ──────────────────────────────────────────── *@
                    @if ( laws.Count < 10 )
                    {
                        <div class="mm-section">
                            <div class="mm-section-label">Proclaim a Law</div>
                            <div class="mm-add-row">
                                <input class="mm-law-input"
                                       type="text"
                                       maxlength="128"
                                       placeholder="e.g. No mugging in the plaza."
                                       value="@NewLawText"
                                       @oninput="@(e => NewLawText = e.Value?.ToString() ?? string.Empty)"
                                       @onkeydown="OnLawKeyDown" />
                                <button class="mm-btn mm-btn-add"
                                        @onclick="AddLaw"
                                        disabled="@string.IsNullOrWhiteSpace( NewLawText )">
                                    Proclaim
                                </button>
                            </div>
                        </div>
                    }

                </div>

                <div class="mm-footer">F6 to close</div>
            </div>
        </div>
    }
</root>

@code {

    bool   IsOpen     { get; set; }
    string NewLawText { get; set; } = string.Empty;

    protected override void OnUpdate()
    {
        var localState = Game.ActiveScene?
            .GetAllComponents<PlayerState>()
            .FirstOrDefault( s => s.Network.OwnerConnection == Connection.Local );

        // Force-close if player is no longer mayor
        if ( IsOpen && localState?.JobId != "mayor" )
        {
            Close();
            return;
        }

        if ( Input.Pressed( "MayorMenu" ) )
            Toggle();
    }

    void Toggle()
    {
        if ( IsOpen ) Close();
        else          Open();
    }

    void Open()
    {
        IsOpen        = true;
        Mouse.Visible = true;
        StateHasChanged();
    }

    void Close()
    {
        IsOpen        = false;
        NewLawText    = string.Empty;
        Mouse.Visible = false;
        StateHasChanged();
    }

    void SetTax( int pct )
    {
        var sys = MayorSys();
        sys?.RequestSetTaxRate( Math.Clamp( pct, 0, 50 ) / 100f );
    }

    void AddLaw()
    {
        var text = NewLawText.Trim();
        if ( string.IsNullOrEmpty( text ) ) return;

        MayorSys()?.RequestAddLaw( text );
        NewLawText = string.Empty;
        StateHasChanged();
    }

    void RemoveLaw( int index )
    {
        MayorSys()?.RequestRemoveLaw( index );
    }

    void ClearLaws()
    {
        MayorSys()?.RequestClearLaws();
    }

    void OnLawKeyDown( KeyboardEventArgs e )
    {
        if ( e.Key == "Enter"  ) AddLaw();
        if ( e.Key == "Escape" ) Close();
    }

    static MayorSystem? MayorSys()
        => Game.ActiveScene?.GetAllComponents<MayorSystem>().FirstOrDefault();

    static int Math_Clamp( int v, int lo, int hi ) => v < lo ? lo : v > hi ? hi : v;

}

<style>
    /* ── Overlay ─────────────────────────────────────────────── */
    .mm-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(0, 0, 0, 0.5);
    }

    /* ── Panel ───────────────────────────────────────────────── */
    .mm-panel {
        width: 480px;
        max-height: 82%;
        background-color: #1a1c20;
        border: 1px solid #4a3800;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        font-family: Poppins, sans-serif;
    }

    /* ── Header ──────────────────────────────────────────────── */
    .mm-header {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        padding: 14px 18px;
        background-color: #1a1200;
        border-bottom: 1px solid #4a3800;
    }

    .mm-title {
        font-size: 16px;
        font-weight: bold;
        color: #ffd966;
    }

    .mm-close-btn {
        background: transparent;
        border: none;
        color: rgba(255, 220, 100, 0.5);
        font-size: 18px;
        cursor: pointer;
        padding: 2px 8px;
        border-radius: 4px;
    }

    .mm-close-btn:hover { background-color: rgba(255,255,255,0.08); color: #ffd966; }

    /* ── Body ────────────────────────────────────────────────── */
    .mm-body {
        display: flex;
        flex-direction: column;
        gap: 0;
        overflow-y: auto;
    }

    /* ── Section ─────────────────────────────────────────────── */
    .mm-section {
        padding: 14px 18px;
        border-bottom: 1px solid #262830;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .mm-section-label {
        font-size: 10px;
        font-weight: bold;
        color: rgba(255, 220, 100, 0.7);
        letter-spacing: 0.8px;
        text-transform: uppercase;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
    }

    .mm-law-count {
        font-size: 10px;
        color: rgba(255,255,255,0.3);
        text-transform: none;
        letter-spacing: 0;
    }

    .mm-empty {
        font-size: 12px;
        color: rgba(255,255,255,0.3);
        font-style: italic;
    }

    /* ── Tax controls ────────────────────────────────────────── */
    .mm-tax-row {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 14px;
    }

    .mm-tax-value {
        font-size: 28px;
        font-weight: bold;
        color: #ffd966;
        min-width: 64px;
        text-align: center;
    }

    .mm-tax-hint {
        font-size: 11px;
        color: rgba(255,255,255,0.4);
    }

    /* ── Laws list ───────────────────────────────────────────── */
    .mm-laws-list {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .mm-law-row {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 8px;
        background-color: rgba(255,255,255,0.04);
        border-radius: 5px;
        padding: 5px 8px;
    }

    .mm-law-text {
        flex: 1;
        font-size: 12px;
        color: rgba(255,255,255,0.8);
    }

    .mm-law-remove {
        background: transparent;
        border: none;
        color: rgba(255, 80, 80, 0.6);
        font-size: 16px;
        cursor: pointer;
        padding: 0 4px;
        border-radius: 3px;
        line-height: 1;
    }

    .mm-law-remove:hover { color: #ff5050; background-color: rgba(255,80,80,0.1); }

    /* ── Add law row ─────────────────────────────────────────── */
    .mm-add-row {
        display: flex;
        flex-direction: row;
        gap: 8px;
    }

    .mm-law-input {
        flex: 1;
        background-color: #22252b;
        border: 1px solid #3a3f4a;
        border-radius: 5px;
        color: white;
        font-size: 12px;
        padding: 7px 10px;
        font-family: Poppins, sans-serif;
        outline: none;
    }

    .mm-law-input::placeholder { color: rgba(255,255,255,0.25); }

    /* ── Shared buttons ──────────────────────────────────────── */
    .mm-btn {
        padding: 7px 16px;
        border: none;
        border-radius: 5px;
        font-size: 12px;
        font-weight: bold;
        cursor: pointer;
        font-family: Poppins, sans-serif;
        color: white;
        white-space: nowrap;
    }

    .mm-btn-minus, .mm-btn-plus {
        background-color: #2e3038;
        color: #ffd966;
        font-size: 13px;
        font-weight: bold;
        min-width: 56px;
    }

    .mm-btn-minus:hover, .mm-btn-plus:hover { background-color: #3e4050; }

    .mm-btn-add  { background-color: #5a4200; color: #ffd966; }
    .mm-btn-add:hover { background-color: #7a5a00; }

    .mm-btn-clear { background-color: #3a1a1a; color: #ff8080; font-size: 11px; }
    .mm-btn-clear:hover { background-color: #5a2a2a; }

    /* ── Footer ──────────────────────────────────────────────── */
    .mm-footer {
        padding: 10px 18px;
        font-size: 10px;
        color: rgba(255, 220, 100, 0.25);
        background-color: #1a1200;
        border-top: 1px solid #4a3800;
        text-align: center;
    }
</style>
